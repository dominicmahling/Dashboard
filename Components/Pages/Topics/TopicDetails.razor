@page "/topics/{id:int}"
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Topic Details</PageTitle>

@if (topic == null)
{
    <div class="loading-placeholder">
        <div class="loading-bar"></div>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1>@topic.Title</h1>
            @if (!string.IsNullOrEmpty(topic.Description))
            {
                <p class="text-muted" style="margin-top:-0.25rem">@topic.Description</p>
            }
        </div>
        <div class="d-flex gap-2">
            <a href="topics/@topic.Id/articles/new" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Article</a>
            <a href="/topics/@topic.Id/edit" class="btn btn-outline-secondary"><i class="bi bi-pencil"></i> Edit</a>
        </div>
    </div>

    @if (!topic.Articles.Any())
    {
        <div class="empty-state">
            <div class="empty-illustration illustration-document">
                <div class="doc-body"></div>
                <div class="doc-fold"></div>
            </div>
            <h3>No articles yet</h3>
            <p>Create your first article in this topic.</p>
            <a href="topics/@topic.Id/articles/new" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Article</a>
        </div>
    }
    else
    {
        <div class="articles-list">
            @foreach (var article in topic.Articles)
            {
                <div class="article-row">
                    <a href="/articles/@article.Id" class="article-row-content">
                        <span class="article-row-title">@article.Title</span>
                        <span class="article-row-meta">Updated @article.UpdatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                    </a>
                    <div class="article-row-actions">
                        <a href="/articles/@article.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-eye"></i></a>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteArticle(article.Id)"><i class="bi bi-trash"></i></button>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    [Parameter] public int Id { get; set; }
    private Topic? topic;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        topic = await db.Topics
            .Include(t => t.Articles)
            .FirstOrDefaultAsync(t => t.Id == Id);

        if (topic == null)
        {
            NavigationManager.NavigateTo("/topics");
        }
    }

    private async Task DeleteArticle(int id)
    {
        if (topic == null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var article = await db.Articles.FindAsync(id);
        if (article != null)
        {
            db.Articles.Remove(article);
            await db.SaveChangesAsync();
            topic.Articles = await db.Articles.Where(a => a.TopicId == Id).ToListAsync();
        }
    }
}
