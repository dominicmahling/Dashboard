@page "/topics/{id:int}/edit"
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Edit Topic</PageTitle>

<h1>Edit Topic</h1>

@if (topic == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <EditForm Model="topic" FormName="edit-topic" OnValidSubmit="HandleValidSubmit" class="mt-3">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label class="form-label">Title</label>
            <InputText @bind-Value="topic.Title" class="form-control" />
            <ValidationMessage For="@(() => topic.Title)" />
        </div>

        <div class="mb-3">
            <label class="form-label">Description</label>
            <InputTextArea @bind-Value="topic.Description" class="form-control" rows="3" />
            <ValidationMessage For="@(() => topic.Description)" />
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/topics" class="btn btn-secondary ms-2">Cancel</a>
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }
    private Topic? topic;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        topic = await db.Topics.FindAsync(Id);
        if (topic == null)
        {
            NavigationManager.NavigateTo("/topics");
        }
    }

    private async Task HandleValidSubmit()
    {
        if (topic == null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        db.Topics.Update(topic);
        await db.SaveChangesAsync();
        NavigationManager.NavigateTo("/topics");
    }
}
