@page "/topics"
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@rendermode InteractiveServer

<PageTitle>Topics</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Topics</h1>
    <a href="topics/new" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Topic</a>
</div>

@if (topics == null)
{
    <div class="loading-placeholder">
        <div class="loading-bar"></div>
    </div>
}
else if (!topics.Any())
{
    <div class="empty-state">
        <div class="empty-illustration illustration-folder">
            <div class="folder-tab"></div>
            <div class="folder-body"></div>
        </div>
        <h3>No topics yet</h3>
        <p>Create your first topic to get started organizing articles and workflows.</p>
        <a href="topics/new" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Create Topic</a>
    </div>
}
else
{
    <div class="topics-grid">
        @foreach (var topic in topics)
        {
            <div class="topic-card">
                <div class="topic-card-body">
                    <a href="topics/@topic.Id" class="topic-card-title">@topic.Title</a>
                    @if (!string.IsNullOrEmpty(topic.Description))
                    {
                        <p class="topic-card-desc">@(topic.Description.Length > 100 ? topic.Description[..100] + "..." : topic.Description)</p>
                    }
                    <div class="topic-card-meta">
                        <span><i class="bi bi-file-text"></i> @topic.ArticleCount article(s)</span>
                        <span><i class="bi bi-calendar3"></i> @topic.CreatedAt.ToString("MMM dd, yyyy")</span>
                    </div>
                </div>
                <div class="topic-card-actions">
                    <a href="topics/@topic.Id/edit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i> Edit</a>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTopic(topic.Id)"><i class="bi bi-trash"></i></button>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<TopicDto> topics = null!;

    protected override async Task OnInitializedAsync()
    {
        await LoadTopics();
    }

    private async Task LoadTopics()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        topics = await db.Topics
            .Select(t => new TopicDto
            {
                Id = t.Id,
                Title = t.Title,
                Description = t.Description,
                CreatedAt = t.CreatedAt,
                ArticleCount = t.Articles.Count
            })
            .ToListAsync();
    }

    private async Task DeleteTopic(int id)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var topic = await db.Topics.Include(t => t.Articles).FirstOrDefaultAsync(t => t.Id == id);
        if (topic != null)
        {
            db.Articles.RemoveRange(topic.Articles);
            db.Topics.Remove(topic);
            await db.SaveChangesAsync();
            await LoadTopics();
        }
    }

    public class TopicDto
    {
        public int Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string? Description { get; set; }
        public DateTime CreatedAt { get; set; }
        public int ArticleCount { get; set; }
    }
}
