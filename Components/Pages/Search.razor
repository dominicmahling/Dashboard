@page "/search"
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@rendermode InteractiveServer

<PageTitle>Search</PageTitle>

<h1>Search</h1>

<div class="search-box mt-3">
    <div class="search-input-group">
        <i class="bi bi-search search-input-icon"></i>
        <input type="text" class="form-control search-input" placeholder="Search topics and articles..." @bind="query" @onkeydown="HandleKeyDown" />
        <button class="btn btn-primary" @onclick="RunSearch">Search</button>
    </div>
</div>

@if (searched && !results.Any())
{
    <div class="empty-state mt-4">
        <div class="empty-illustration illustration-search">
            <div class="search-lens"></div>
            <div class="search-handle"></div>
        </div>
        <h3>No results found</h3>
        <p>Try a different search term.</p>
    </div>
}
else if (results.Any())
{
    <div class="mt-4">
        <div class="d-flex align-items-center gap-2 mb-3">
            <h5 style="margin:0;color:var(--text-secondary)">@results.Count result(s)</h5>
        </div>
        <div class="search-results">
            @foreach (var r in results)
            {
                <a href="@r.Url" class="search-result-item">
                    <div class="search-result-type @(r.Type == "Topic" ? "type-topic" : "type-article")">
                        @if (r.Type == "Topic")
                        {
                            <i class="bi bi-folder-fill"></i>
                        }
                        else
                        {
                            <i class="bi bi-file-text-fill"></i>
                        }
                    </div>
                    <div class="search-result-content">
                        <span class="search-result-title">@r.Title</span>
                        @if (!string.IsNullOrEmpty(r.Preview))
                        {
                            <span class="search-result-preview">@r.Preview</span>
                        }
                        <span class="search-result-type-label">@r.Type</span>
                    </div>
                    <i class="bi bi-chevron-right search-result-arrow"></i>
                </a>
            }
        </div>
    </div>
}

@code {
    private string query = "";
    private bool searched;
    private List<SearchResult> results = new();

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await RunSearch();
    }

    private async Task RunSearch()
    {
        if (string.IsNullOrWhiteSpace(query)) return;
        searched = true;
        var q = query.ToLower();

        await using var db = await DbFactory.CreateDbContextAsync();

        var topicResults = await db.Topics
            .Where(t => t.Title.ToLower().Contains(q) || (t.Description != null && t.Description.ToLower().Contains(q)))
            .Select(t => new SearchResult { Type = "Topic", Title = t.Title, Preview = t.Description, Url = $"/topics/{t.Id}" })
            .ToListAsync();

        var articleResults = await db.Articles
            .Where(a => a.Title.ToLower().Contains(q) || (a.Content != null && a.Content.ToLower().Contains(q)))
            .ToListAsync();

        results = topicResults.Concat(articleResults.Select(a => new SearchResult
        {
            Type = "Article",
            Title = a.Title,
            Preview = a.Content != null && a.Content.Length > 150 ? a.Content.Substring(0, 150) + "..." : a.Content,
            Url = $"/articles/{a.Id}"
        })).ToList();
    }

    private class SearchResult
    {
        public string Type { get; set; } = "";
        public string Title { get; set; } = "";
        public string? Preview { get; set; }
        public string Url { get; set; } = "";
    }
}
