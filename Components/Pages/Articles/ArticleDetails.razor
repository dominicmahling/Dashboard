@page "/articles/{id:int}"
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>@(article?.Title ?? "Article")</PageTitle>

@if (article == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>@article.Title</h1>
        <div>
            <button class="btn @(editMode ? "btn-primary" : "btn-outline-secondary")" @onclick="ToggleEdit">
                @(editMode ? "Done Editing" : "Edit")
            </button>
            <a href="/articles/@article.Id/edit" class="btn btn-outline-secondary ms-2">Settings</a>
            <button class="btn btn-outline-danger ms-2" @onclick="DeleteArticle">Delete</button>
        </div>
    </div>

    <p class="text-muted mb-4">
        Topic: <a href="/topics/@article.TopicId" class="text-decoration-none">@article.Topic?.Title</a>
        &middot; Updated: @article.UpdatedAt.ToString("yyyy-MM-dd HH:mm")
    </p>

    <div id="field-container">
        @if (editMode)
        {
            @for (int i = 0; i < fields.Count; i++)
            {
                var f = fields[i];
                var idx = i;
                <div class="field-block" data-field-id="@f.Id">
                    <div class="field-header">
                        <span class="drag-handle">&#9776;</span>
                        <span class="badge bg-secondary">@f.FieldType</span>
                        <button class="btn btn-sm btn-outline-success ms-2" @onclick="() => MoveFieldUp(idx)" disabled="@(idx == 0)">&#8593;</button>
                        <button class="btn btn-sm btn-outline-success" @onclick="() => MoveFieldDown(idx)" disabled="@(idx == fields.Count - 1)">&#8595;</button>
                        <button class="btn btn-sm btn-outline-danger ms-auto" @onclick="() => DeleteField(f.Id)">&#x2715;</button>
                    </div>
                    <div class="field-body">
                        @if (f.FieldType == "text")
                        {
                            <textarea class="form-control" rows="6" @bind="f.Content" @bind:after="() => SaveField(f)"></textarea>
                        }
                        else if (f.FieldType == "workflow")
                        {
                            var steps = f.Steps.ToList();
                            if (steps.Any())
                            {
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <small class="text-muted">@steps.Count step(s)</small>
                                    <button class="btn btn-sm btn-outline-warning py-0" @onclick="() => ResetWorkflow(f.Id)">Reset all</button>
                                </div>
                                <div class="mb-1">
                                    @for (int si = 0; si < steps.Count; si++)
                                    {
                                        var s = steps[si];
                                        <div class="d-flex align-items-center gap-2 mb-1 p-1 rounded @(s.Completed ? "bg-success bg-opacity-10" : "")">
                                            <span class="badge @(s.Completed ? "bg-success" : "bg-secondary")">@(s.Completed ? "✓" : (si + 1).ToString())</span>
                                            <span class="flex-grow-1 small">@s.Name</span>
                                            @if (!s.Completed)
                                            {
                                                <button class="btn btn-sm btn-outline-primary py-0 px-1" @onclick="() => QuickCompleteStep(s.Id)">Done</button>
                                            }
                                            @if (s.Completed)
                                            {
                                                <small class="text-muted" title="Completed @(s.CompletedAt?.ToString("yyyy-MM-dd HH:mm") ?? "")">&#10003;</small>
                                            }
                                            <button class="btn btn-sm btn-outline-danger py-0 px-1" @onclick="() => QuickRemoveStep(s.Id)">&times;</button>
                                        </div>
                                    }
                                </div>
                            }
                            <div class="mt-1">
                                <div class="row g-1">
                                    <div class="col-12">
                                        <input type="text" class="form-control form-control-sm" placeholder="Step name" @bind="newStepName" />
                                    </div>
                                    <div class="col-8">
                                        <textarea class="form-control form-control-sm" rows="2" placeholder="Description (optional)" @bind="newStepDesc"></textarea>
                                    </div>
                                    <div class="col-4 d-flex align-items-end">
                                        <button class="btn btn-success btn-sm w-100" @onclick="() => QuickAddStep(f.Id)">Add</button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="mt-3">
                <button class="btn btn-success me-2" @onclick="() => AddText()">+ Text</button>
                <button class="btn btn-success" @onclick="() => AddWorkflow()">+ Workflow</button>
            </div>
        }
        else
        {
            @foreach (var field in fields)
            {
                if (field.FieldType == "text" && !string.IsNullOrWhiteSpace(field.Content))
                {
                    <div class="mb-3">@((MarkupString)FormatContent(field.Content))</div>
                }
                else if (field.FieldType == "workflow" && field.Steps.Any())
                {
                    var steps = field.Steps.ToList();
                    var currentIdx = steps.FindIndex(s => !s.Completed);
                    if (currentIdx == -1 && steps.Any()) currentIdx = steps.Count - 1;
                    @if (steps.Any(s => s.Completed))
                    {
                        <div class="d-flex justify-content-end mb-1">
                            <button class="btn btn-sm btn-outline-warning py-0" @onclick="() => ResetWorkflow(field.Id)">Reset all</button>
                        </div>
                    }
                    @for (int si = 0; si < steps.Count; si++)
                    {
                        var s = steps[si];
                        var isCur = si == currentIdx && !s.Completed;
                        <div class="d-flex align-items-center gap-2 mb-1 p-1 rounded small @(isCur ? "current-step" : "") @(s.Completed ? "done-step" : "")">
                            <span class="badge rounded-pill @(s.Completed ? "bg-success" : isCur ? "bg-primary" : "bg-secondary")">@(s.Completed ? "✓" : (si + 1).ToString())</span>
                            <span class="flex-grow-1">@s.Name</span>
                            @if (isCur)
                            {
                                <button class="btn btn-sm btn-primary py-0 px-2" @onclick="() => QuickCompleteStep(s.Id)">Complete</button>
                            }
                            else if (s.Completed)
                            {
                                <span class="text-muted small">Done @(s.CompletedAt?.ToString("MMM dd HH:mm") ?? "")</span>
                            }
                        </div>
                    }
                }
            }
        }
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private Article? article;
    private List<ArticleField> fields = new();
    private bool editMode;
    private DotNetObjectReference<ArticleDetails>? dotNetRef;
    private string newStepName = "";
    private string newStepDesc = "";

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        article = await db.Articles.FindAsync(Id);
        if (article == null)
        {
            NavigationManager.NavigateTo("/topics");
            return;
        }

        await db.Entry(article).Reference(a => a.Topic).LoadAsync();
        await LoadFields();
    }

    private async Task LoadFields()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        fields = await db.ArticleFields
            .Where(f => f.ArticleId == Id)
            .OrderBy(f => f.Order)
            .ToListAsync();

        foreach (var field in fields.Where(f => f.FieldType == "workflow"))
        {
            field.Steps = await db.WorkflowSteps
                .Where(s => s.ArticleFieldId == field.Id)
                .OrderBy(s => s.Order)
                .ToListAsync();
        }
    }

    private IJSObjectReference? fieldEditorModule;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            fieldEditorModule = await JS.InvokeAsync<IJSObjectReference>("import", "/js/field-editor.js");
        }

        try
        {
            if (editMode)
            {
                dotNetRef ??= DotNetObjectReference.Create(this);
                if (fieldEditorModule != null)
                    await fieldEditorModule.InvokeVoidAsync("init", "field-container", dotNetRef);
            }
            else if (dotNetRef != null)
            {
                if (fieldEditorModule != null)
                    await fieldEditorModule.InvokeVoidAsync("destroy");
            }
        }
        catch
        {
        }
    }

    private async Task ToggleEdit()
    {
        if (editMode)
        {
            try
            {
                if (fieldEditorModule != null)
                    await fieldEditorModule.InvokeVoidAsync("destroy");
            }
            catch { }
            await SaveAllFields();
            await LoadFields();
        }
        editMode = !editMode;
        StateHasChanged();
    }

    private async Task QuickAddStep(int fieldId)
    {
        if (string.IsNullOrWhiteSpace(newStepName)) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var step = new WorkflowStep
        {
            Name = newStepName.Trim(),
            Description = newStepDesc.Trim(),
            Order = fields.First(f => f.Id == fieldId).Steps.Count,
            ArticleFieldId = fieldId
        };
        db.WorkflowSteps.Add(step);
        await db.SaveChangesAsync();
        fields.First(f => f.Id == fieldId).Steps.Add(step);
        newStepName = "";
        newStepDesc = "";
        StateHasChanged();
    }

    private async Task QuickCompleteStep(int stepId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var step = await db.WorkflowSteps.FindAsync(stepId);
        if (step != null)
        {
            step.Completed = !step.Completed;
            step.CompletedAt = step.Completed ? DateTime.UtcNow : null;
            step.CompletedBy = step.Completed ? "local" : null;
            await db.SaveChangesAsync();
        }
        foreach (var f in fields)
        {
            var s = f.Steps.FirstOrDefault(x => x.Id == stepId);
            if (s != null)
            {
                s.Completed = !s.Completed;
                s.CompletedAt = s.Completed ? DateTime.UtcNow : null;
                s.CompletedBy = s.Completed ? "local" : null;
            }
        }
        StateHasChanged();
    }

    private async Task ResetWorkflow(int fieldId)
    {
        var field = fields.FirstOrDefault(f => f.Id == fieldId);
        if (field == null) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var steps = await db.WorkflowSteps.Where(s => s.ArticleFieldId == fieldId).ToListAsync();
        foreach (var s in steps)
        {
            s.Completed = false;
            s.CompletedAt = null;
            s.CompletedBy = null;
        }
        await db.SaveChangesAsync();

        foreach (var s in field.Steps)
        {
            s.Completed = false;
            s.CompletedAt = null;
            s.CompletedBy = null;
        }

        StateHasChanged();
    }

    private async Task QuickRemoveStep(int stepId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var step = await db.WorkflowSteps.FindAsync(stepId);
        if (step != null)
        {
            db.WorkflowSteps.Remove(step);
            await db.SaveChangesAsync();
        }
        foreach (var f in fields)
        {
            var list = f.Steps.ToList();
            list.RemoveAll(s => s.Id == stepId);
            f.Steps = list;
        }
        StateHasChanged();
    }

    private async Task AddText() => await AddField("text");
    private async Task AddWorkflow() => await AddField("workflow");

    private async Task AddField(string fieldType)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var field = new ArticleField
        {
            FieldType = fieldType,
            Order = fields.Count,
            ArticleId = Id
        };
        db.ArticleFields.Add(field);
        await db.SaveChangesAsync();
        field.Steps = new List<WorkflowStep>();
        fields.Add(field);
        StateHasChanged();
    }

    private async Task DeleteField(int fieldId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var field = await db.ArticleFields.Include(f => f.Steps).FirstOrDefaultAsync(f => f.Id == fieldId);
        if (field != null)
        {
            db.WorkflowSteps.RemoveRange(field.Steps);
            db.ArticleFields.Remove(field);
            await db.SaveChangesAsync();
        }
        fields.RemoveAll(f => f.Id == fieldId);
        StateHasChanged();
    }

    private async Task MoveFieldUp(int index)
    {
        if (index <= 0) return;
        (fields[index], fields[index - 1]) = (fields[index - 1], fields[index]);
        StateHasChanged();
    }

    private async Task MoveFieldDown(int index)
    {
        if (index >= fields.Count - 1) return;
        (fields[index], fields[index + 1]) = (fields[index + 1], fields[index]);
        StateHasChanged();
    }

    private async Task SaveField(ArticleField field)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var existing = await db.ArticleFields.FindAsync(field.Id);
        if (existing != null)
        {
            existing.Content = field.Content;
            await db.SaveChangesAsync();
        }
    }

    private async Task SaveAllFields()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        for (int i = 0; i < fields.Count; i++)
        {
            var existing = await db.ArticleFields.FindAsync(fields[i].Id);
            if (existing != null)
            {
                existing.Content = fields[i].Content;
                existing.Order = i;
            }
        }
        await db.SaveChangesAsync();
    }

    [JSInvokable]
    public async Task ReorderFields(List<FieldOrder> orderList)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        foreach (var item in orderList)
        {
            var existing = await db.ArticleFields.FindAsync(item.Id);
            if (existing != null)
            {
                existing.Order = item.Order;
            }
        }
        await db.SaveChangesAsync();
        await LoadFields();
        StateHasChanged();
    }

    private async Task DeleteArticle()
    {
        if (article == null) return;
        var topicId = article.TopicId;
        await using var db = await DbFactory.CreateDbContextAsync();
        var a = await db.Articles.FindAsync(article.Id);
        if (a != null)
        {
            var articleFields = await db.ArticleFields.Include(f => f.Steps).Where(f => f.ArticleId == article.Id).ToListAsync();
            foreach (var f in articleFields)
            {
                db.WorkflowSteps.RemoveRange(f.Steps);
            }
            db.ArticleFields.RemoveRange(articleFields);
            db.Articles.Remove(a);
            await db.SaveChangesAsync();
        }
        NavigationManager.NavigateTo($"/topics/{topicId}");
    }

    private static string FormatContent(string? content)
    {
        if (string.IsNullOrEmpty(content)) return "";
        return System.Net.WebUtility.HtmlEncode(content).Replace("\n", "<br>");
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (fieldEditorModule != null)
            {
                await fieldEditorModule.InvokeVoidAsync("destroy");
                await fieldEditorModule.DisposeAsync();
            }
            if (dotNetRef != null) dotNetRef.Dispose();
        }
        catch
        {
            dotNetRef?.Dispose();
        }
    }

    public class FieldOrder
    {
        public int Id { get; set; }
        public int Order { get; set; }
    }
}
