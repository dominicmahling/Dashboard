@page "/articles/{id:int}/workflow"
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Workflow</PageTitle>

@if (article == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-1">Workflow</h1>
            <p class="text-muted mb-0">@article.Title</p>
        </div>
        <div>
            <button class="btn btn-outline-warning me-2" @onclick="ResetWorkflow">Reset</button>
            <a href="/articles/@article.Id" class="btn btn-outline-secondary">Back to Article</a>
        </div>
    </div>

    @if (steps.Any())
    {
        <div class="workflow-list">
            @foreach (var (step, index) in steps.Select((s, i) => (s, i)))
            {
                var isCurrent = index == currentStep && !step.Completed;
                <div class="workflow-step-item @(isCurrent ? "current" : "") @(step.Completed ? "done" : "")">
                    <div class="step-header">
                        <div class="step-indicator @(isCurrent ? "active" : "") @(step.Completed ? "completed" : "")">
                            @if (step.Completed)
                            {
                                <span>&#10003;</span>
                            }
                            else
                            {
                                @(index + 1)
                            }
                        </div>
                        <div class="step-info">
                            <h5 class="step-name">@step.Name</h5>
                            @if (!string.IsNullOrEmpty(step.Description))
                            {
                                <p class="step-desc">@step.Description</p>
                            }
                        </div>
                        <div class="step-actions">
                            @if (isCurrent)
                            {
                                <button class="btn btn-primary btn-sm" @onclick="() => CompleteStep(index)">Mark Complete</button>
                            }
                            else if (step.Completed)
                            {
                                <span class="badge bg-success">Done</span>
                            }
                            <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => RemoveStepByIndex(index)" title="Remove step">&times;</button>
                        </div>
                    </div>
                </div>
                @if (index < steps.Count - 1)
                {
                    <div class="step-divider @(step.Completed ? "completed" : "")"></div>
                }
            }
        </div>
    }
    else
    {
        <p class="text-muted">No steps yet. Add one below.</p>
    }

    <div class="card mt-4">
        <div class="card-body">
            <h6>Add Step</h6>
            <div class="row g-2">
                <div class="col-md-4">
                    <input type="text" class="form-control" placeholder="Step name" @bind="newStepName" />
                </div>
                <div class="col-md-6">
                    <input type="text" class="form-control" placeholder="Description (optional)" @bind="newStepDesc" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-success w-100" @onclick="AddStep">Add</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private Article? article;
    private List<WorkflowStep> steps = new();
    private int currentStep = 0;
    private string newStepName = "";
    private string newStepDesc = "";

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        article = await db.Articles.FindAsync(Id);
        if (article == null)
        {
            NavigationManager.NavigateTo("/topics");
            return;
        }

        steps = await db.WorkflowSteps
            .Where(ws => ws.ArticleId == Id)
            .OrderBy(ws => ws.Order)
            .ToListAsync();

        currentStep = steps.FindIndex(s => !s.Completed);
        if (currentStep == -1 && steps.Any())
        {
            currentStep = steps.Count - 1;
        }
    }

    private async Task CompleteStep(int index)
    {
        if (index < 0 || index >= steps.Count) return;

        steps[index].Completed = true;
        steps[index].CompletedAt = DateTime.UtcNow;

        await using var db = await DbFactory.CreateDbContextAsync();
        db.WorkflowSteps.Update(steps[index]);
        await db.SaveChangesAsync();

        var nextIncomplete = steps.FindIndex(s => !s.Completed);
        currentStep = nextIncomplete == -1 ? steps.Count - 1 : nextIncomplete;

        if (nextIncomplete == -1)
        {
            await Task.Delay(1000);
            await ResetWorkflow();
        }

        StateHasChanged();
    }

    private async Task AddStep()
    {
        if (string.IsNullOrWhiteSpace(newStepName) || article == null) return;

        var step = new WorkflowStep
        {
            Name = newStepName.Trim(),
            Description = newStepDesc.Trim(),
            Order = steps.Count,
            ArticleId = article.Id
        };

        await using var db = await DbFactory.CreateDbContextAsync();
        db.WorkflowSteps.Add(step);
        await db.SaveChangesAsync();

        steps.Add(step);
        newStepName = "";
        newStepDesc = "";
        StateHasChanged();
    }

    private async Task RemoveStepByIndex(int index)
    {
        if (index < 0 || index >= steps.Count) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var step = await db.WorkflowSteps.FindAsync(steps[index].Id);
        if (step != null)
        {
            db.WorkflowSteps.Remove(step);
            await db.SaveChangesAsync();
            steps.RemoveAt(index);

            if (currentStep >= steps.Count)
            {
                currentStep = Math.Max(0, steps.Count - 1);
            }

            StateHasChanged();
        }
    }

    private async Task ResetWorkflow()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var workflowSteps = await db.WorkflowSteps.Where(ws => ws.ArticleId == Id).ToListAsync();
        foreach (var step in workflowSteps)
        {
            step.Completed = false;
            step.CompletedAt = null;
        }
        await db.SaveChangesAsync();

        foreach (var step in steps)
        {
            step.Completed = false;
            step.CompletedAt = null;
        }

        currentStep = 0;
        StateHasChanged();
    }
}
