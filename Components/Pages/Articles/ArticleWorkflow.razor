@page "/articles/{id:int}/workflow"
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Workflow</PageTitle>

@if (article == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-1">Workflow</h1>
            <p class="text-muted mb-0">@article.Title</p>
        </div>
        <a href="/articles/@article.Id" class="btn btn-outline-secondary">Back to Article</a>
    </div>

    <div class="row">
        <div class="col-md-4">
            <WorkflowSteps CurrentStep="currentStep" Steps="workflowStepItems" OnStepClick="GoToStep" OnRemoveStep="RemoveStepByIndex" />

            <div class="mt-4">
                <h6>Add Step</h6>
                <div class="input-group input-group-sm mb-2">
                    <input type="text" class="form-control" placeholder="Step name" @bind="newStepName" />
                    <button class="btn btn-success" @onclick="AddStep">Add</button>
                </div>
                <input type="text" class="form-control form-control-sm mb-2" placeholder="Description (optional)" @bind="newStepDesc" />

                <button class="btn btn-outline-warning btn-sm" @onclick="ResetWorkflow">Reset Workflow</button>
            </div>
        </div>

        <div class="col-md-8">
            @if (steps.Any() && currentStep >= 0 && currentStep < steps.Count)
            {
                var step = steps[currentStep];
                <div class="card">
                    <div class="card-body">
                        <h5>@step.Name</h5>
                        @if (!string.IsNullOrEmpty(step.Description))
                        {
                            <p class="text-muted">@step.Description</p>
                        }
                        @if (!step.Completed)
                        {
                            <button class="btn btn-primary mt-2" @onclick="() => CompleteStep(currentStep)">Mark Complete</button>
                        }
                        else
                        {
                            <span class="badge bg-success mt-2">Completed</span>
                        }
                    </div>
                </div>
            }
            else if (!steps.Any())
            {
                <p class="text-muted">No steps yet. Add your first step on the left.</p>
            }
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private Article? article;
    private List<WorkflowStep> steps = new();
    private List<WorkflowSteps.WorkflowStepItem> workflowStepItems = new();
    private int currentStep = 0;
    private string newStepName = "";
    private string newStepDesc = "";

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        article = await db.Articles.FindAsync(Id);
        if (article == null)
        {
            NavigationManager.NavigateTo("/topics");
            return;
        }

        steps = await db.WorkflowSteps
            .Where(ws => ws.ArticleId == Id)
            .OrderBy(ws => ws.Order)
            .ToListAsync();

        workflowStepItems = steps.Select(s => new WorkflowSteps.WorkflowStepItem
        {
            Name = s.Name,
            Completed = s.Completed
        }).ToList();

        currentStep = steps.FindIndex(s => !s.Completed);
        if (currentStep == -1 && steps.Any())
        {
            currentStep = steps.Count - 1;
        }
    }

    private void GoToStep(int index)
    {
        if (index >= 0 && index < steps.Count)
        {
            currentStep = index;
        }
    }

    private async Task CompleteStep(int index)
    {
        if (index < 0 || index >= steps.Count) return;

        steps[index].Completed = true;
        steps[index].CompletedAt = DateTime.UtcNow;
        workflowStepItems[index].Completed = true;

        await using var db = await DbFactory.CreateDbContextAsync();
        db.WorkflowSteps.Update(steps[index]);
        await db.SaveChangesAsync();

        var nextIncomplete = steps.FindIndex(s => !s.Completed);
        currentStep = nextIncomplete == -1 ? steps.Count - 1 : nextIncomplete;

        if (nextIncomplete == -1)
        {
            await Task.Delay(1000);
            await ResetWorkflow();
        }

        StateHasChanged();
    }

    private async Task AddStep()
    {
        if (string.IsNullOrWhiteSpace(newStepName) || article == null) return;

        var step = new WorkflowStep
        {
            Name = newStepName.Trim(),
            Description = newStepDesc.Trim(),
            Order = steps.Count,
            ArticleId = article.Id
        };

        await using var db = await DbFactory.CreateDbContextAsync();
        db.WorkflowSteps.Add(step);
        await db.SaveChangesAsync();

        steps.Add(step);
        workflowStepItems.Add(new() { Name = step.Name, Completed = false });
        newStepName = "";
        newStepDesc = "";
        StateHasChanged();
    }

    private async Task RemoveStepByIndex(int index)
    {
        if (index < 0 || index >= steps.Count) return;
        await RemoveStep(steps[index].Id);
    }

    private async Task RemoveStep(int stepId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var step = await db.WorkflowSteps.FindAsync(stepId);
        if (step != null)
        {
            db.WorkflowSteps.Remove(step);
            await db.SaveChangesAsync();
            steps.RemoveAll(s => s.Id == stepId);
            workflowStepItems.RemoveAll(s => s.Name == step.Name);

            if (currentStep >= steps.Count)
            {
                currentStep = Math.Max(0, steps.Count - 1);
            }

            StateHasChanged();
        }
    }

    private async Task ResetWorkflow()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var workflowSteps = await db.WorkflowSteps.Where(ws => ws.ArticleId == Id).ToListAsync();
        foreach (var step in workflowSteps)
        {
            step.Completed = false;
            step.CompletedAt = null;
        }
        await db.SaveChangesAsync();

        foreach (var step in steps)
        {
            step.Completed = false;
            step.CompletedAt = null;
        }

        foreach (var item in workflowStepItems)
        {
            item.Completed = false;
        }

        currentStep = 0;
        StateHasChanged();
    }
}
