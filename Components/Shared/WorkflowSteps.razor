<div class="workflow-steps">
    @for (int i = 0; i < Steps.Count; i++)
    {
        var index = i;
        var step = Steps[index];
        var isCurrent = index == CurrentStep;
        var cssClass = isCurrent ? "active" : step.Completed ? "completed" : "";

        <div class="step @cssClass" @onclick="() => OnStepClick.InvokeAsync(index)">
            <div class="step-indicator">
                @if (step.Completed)
                {
                    <span class="checkmark">&#10003;</span>
                }
                else
                {
                    @(index + 1)
                }
            </div>
            <div class="step-label">@step.Name</div>
            @if (!step.Completed)
            {
                <button class="step-remove" @onclick:stopPropagation @onclick="() => OnRemoveStep.InvokeAsync(index)" title="Remove step">&times;</button>
            }
        </div>

        @if (index < Steps.Count - 1)
        {
            <div class="step-connector @(step.Completed ? "completed" : "")"></div>
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public int CurrentStep { get; set; }
    [Parameter, EditorRequired] public List<WorkflowStepItem> Steps { get; set; } = new();
    [Parameter] public EventCallback<int> OnStepClick { get; set; }
    [Parameter] public EventCallback<int> OnRemoveStep { get; set; }

    public class WorkflowStepItem
    {
        public string Name { get; set; } = "";
        public bool Completed { get; set; }
    }
}
